<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_period_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="This Week"
            android:textColor="#9090B0"
            android:textSize="11sp"
            android:letterSpacing="0.08"
            android:textAllCaps="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💰"
            android:textSize="14sp" />

    </LinearLayout>

    <!-- Spent / Budget large line -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_spent_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$0"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_budget_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=" / $0"
            android:textColor="#9090B0"
            android:textSize="14sp"
            android:layout_marginBottom="3dp" />

    </LinearLayout>

    <!-- Progress bar -->
    <ProgressBar
        android:id="@+id/widget_progress"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:progressDrawable="@drawable/widget_progress_fill"
        android:max="100"
        android:progress="0"
        android:layout_marginBottom="10dp" />

    <!-- Status line -->
    <TextView
        android:id="@+id/widget_status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No spending logged yet"
        android:textColor="#9090B0"
        android:textSize="11sp"
        android:singleLine="true"
        android:ellipsize="end"
        android:layout_marginBottom="10dp" />

    <!-- Add spending button -->
    <TextView
        android:id="@+id/widget_summary_add_btn"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:text="＋  Log Spending"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:gravity="center"
        android:background="@drawable/widget_add_pill" />

</LinearLayout>
